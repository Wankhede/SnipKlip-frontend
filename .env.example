# Public browser configuration
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8082/
NEXT_PUBLIC_FRONTEND_URL=http://localhost:8083/
NEXT_PUBLIC_COMPANY_NAME=SnipKlip
NEXT_PUBLIC_COMPANY_WEBSITE=https://snipklip.in
NEXT_PUBLIC_SUPPORT_EMAIL=support@snipklip.in
NEXT_PUBLIC_ADMIN_EMAIL=admin@snipklip.in
NEXT_PUBLIC_CONTACT_NUMBER=
NEXT_PUBLIC_BLOG_URL=https://snipklip.in/blog
NEXT_PUBLIC_BROCHURE_LINK=https://snipklip.in/SnipKlip-Brochure.pdf
NEXT_PUBLIC_LOGO=/assets/images/logo-white.svg
NEXT_PUBLIC_LOGO_DARK=/assets/images/logo-black.svg
NEXT_PUBLIC_FAVICON=/favicon.svg
NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_LINKEDIN=
NEXT_PUBLIC_SOCIAL_FACEBOOK=

# Server-only NextAuth configuration
NEXTAUTH_URL=http://localhost:8083/
NEXTAUTH_SECRET=replace-with-a-new-random-secret
JWT_TIMEOUT=86400
JWT_SECRET=replace-with-a-new-random-secret

# Server-only OAuth credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public payment identifier only; never expose a payment secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Server-side storage configuration (do not import into browser code)
AWS_REGION=eu-north-1
AWS_S3_BUCKET=snipklip-invoices
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional integrations
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_TAWK_PROPERTY_ID=
NEXT_PUBLIC_TAWK_WIDGET_ID=
